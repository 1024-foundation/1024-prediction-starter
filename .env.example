# ── 1024 Public API ─────────────────────────────────────────────────────────
# Base URL of the 1024 Public API. Defaults to mainnet (real, live markets).
# To place TEST orders safely, switch to testnet-stable (free test USDC):
#   API_1024_BASE=https://api-testnet-stable.1024ex.com
# ⚠ With a mainnet key configured below, orders placed here are REAL.
API_1024_BASE=https://api-mainnet.1024ex.com

# ── Custodial trading credentials (OPTIONAL) ────────────────────────────────
# Leave BLANK to run the demo in read-only mode — you can still browse every
# collection, market and order book (those endpoints are public).
#
# To place orders you need an API key + secret for a 1024 account. These are
# SECRETS: they live only on the server (this file is git-ignored) and are used
# by the signing proxy in src/app/api — they are NEVER sent to the browser.
API_1024_KEY=
API_1024_SECRET=
